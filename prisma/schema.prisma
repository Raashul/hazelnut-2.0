generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  FAKE
}

// ─── Global / shared tables ───────────────────────────────────────────────────

model BooksCache {
  isbn13        String   @id
  volumeId      String   @unique
  title         String
  authors       String[]
  coverUrl      String?
  rating        Float?
  publishedYear Int?
  pageCount     Int?
  description   String?
  sourcePayload Json
  createdAt     DateTime @default(now())

  enrichment        EnrichmentCache?
  genres            BookGenre[]
  exploreBooks      ExploreBook[]
  collectionEntries CollectionEntry[]

  @@map("books_cache")
}

// Genre membership pool for a book — populated by the manual explore-catalog
// population script. isActive supports future soft-removal without deleting
// the underlying book row.
model BookGenre {
  id       String   @id @default(cuid())
  isbn13   String
  genre    String
  isActive Boolean  @default(true)
  addedAt  DateTime @default(now())

  book BooksCache @relation(fields: [isbn13], references: [isbn13])

  @@unique([isbn13, genre])
  @@index([genre, isActive])
  @@map("book_genres")
}

// The currently-displayed explore selection per genre. Fully replaced (wiped
// + reinserted) by the manual refresh script — never accumulates indefinitely.
model ExploreBook {
  id         String   @id @default(cuid())
  genre      String
  isbn13     String
  selectedAt DateTime @default(now())

  book BooksCache @relation(fields: [isbn13], references: [isbn13])

  @@unique([genre, isbn13])
  @@index([genre])
  @@map("explore_books")
}

// Reviews are stored as a JSON array of objects:
// { quote_text, attributed_to, source_name, source_url, source_date,
//   confidence, verification_status: "unverified" | "verified" | "fake" }
//
// Reads filter out any review where verification_status = "fake".
model EnrichmentCache {
  id          String           @id @default(cuid())
  isbn13      String           @unique
  reviews     Json             @default("[]")
  status      EnrichmentStatus @default(PENDING)
  retryCount  Int              @default(0)
  failedAt    DateTime?
  generatedAt DateTime         @default(now())

  book BooksCache @relation(fields: [isbn13], references: [isbn13])

  @@map("enrichment_cache")
}

// Normalized query → ordered list of isbn13s / volumeIds. TTL ~30 days enforced in app.
model QueryCache {
  normalizedQuery String   @id
  resultIds       String[]
  cachedAt        DateTime @default(now())

  @@map("query_cache")
}

// ─── Per-user tables ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  collectionEntries CollectionEntry[]

  @@map("users")
}

// A book the user has already read, added from the book detail view.
// Optional dateRead / review — both filled in only if the user chooses to.
model CollectionEntry {
  id        String    @id @default(cuid())
  userId    String
  isbn13    String
  dateRead  DateTime?
  review    String?
  createdAt DateTime  @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  book BooksCache @relation(fields: [isbn13], references: [isbn13])

  @@unique([userId, isbn13])
  @@map("collection_entries")
}
